# Which AI backend rewords findings (Phase 6). Both only reword — never change a
# verdict (severity/state/control_id/location stay scanner-owned).
#   byok    -> your own provider key (the default; OpenAI/Anthropic/Gemini/Azure)
#   copilot -> the bundled GitHub Copilot CLI (see COPILOT_* below)
AI_BACKEND=byok

# BYOK: at least one provider key required (for the provider you select below).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Azure OpenAI (provider "azure"): key + endpoint + deployment are all required.
AZURE_API_KEY=
AZURE_OPENAI_ENDPOINT=                 # e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=              # the deployment name (falls back to the model id)
AZURE_OPENAI_API_VERSION=2024-10-21

DEFAULT_LLM_PROVIDER=anthropic        # openai | anthropic | google | azure
# Pin a dated snapshot (e.g. an "...-2025-xx-xx" id) rather than a moving alias
# so model upgrades don't silently change review output over time.
DEFAULT_LLM_MODEL=claude-sonnet-4-5
DEFAULT_LLM_TEMPERATURE=0.0
# Best-effort reproducible sampling on OpenAI (ignored by Anthropic/Google).
# Set to `none` to disable (blank is treated as unset and keeps the default).
# Note: reasoning models (e.g. gpt-5*) still vary some.
DEFAULT_LLM_SEED=7
# When false, the LLM may only reword scanner findings — it can't invent new
# `*:llm-` findings, so the finding set is stable run-to-run. Set true for more
# coverage at the cost of consistency.
ENABLE_LLM_FINDINGS=false

# GitHub Copilot backend (only used when AI_BACKEND=copilot). Needs the Copilot
# CLI installed alongside (Node) + a token; leave unset to use BYOK.
COPILOT_GITHUB_TOKEN=
COPILOT_CLI_COMMAND=copilot           # the CLI to invoke (must be on PATH)
COPILOT_TIMEOUT_SECONDS=120

# Which review lenses to run, as a comma-separated list of ids (e.g.
# "security,style"). Empty = every registered lens that applies to the repo.
# A lens runs only when selected here AND applicable (e.g. cost needs an
# infracost key). Registered lenses: security, cost, style.
ENABLED_LENSES=

# Scan scope (Phase 10). "full" (default) reviews the whole repo — the assessor
# posture scan; "diff" scopes scanner findings to the files this PR changed.
# Repo-level lenses (A1/A2/A5, gap detection) are always whole-repo.
SCAN_MODE=full
# Post a PR review with a comment on each finding sitting on a changed line
# (on by default). Findings off the diff stay in the sticky summary. Re-runs are
# idempotent (a hidden per-finding marker dedupes).
INLINE_COMMENTS=true

# External check sources (Phase 3). Each tool runs as its own CI step and writes
# a SARIF report; point these at the report to ingest its findings. Empty = the
# source is skipped (engine behaviour unchanged). Findings keep the producing
# tool + rule id (e.g. `trivy:CVE-...`).
#   prowler / gitleaks / trivy -> security lens · megalinter -> style lens
PROWLER_SARIF_PATH=
GITLEAKS_SARIF_PATH=
TRIVY_SARIF_PATH=
MEGALINTER_SARIF_PATH=
# Coverage report (lcov .info / cobertura.xml / jacoco.xml) for the A3 lens.
COVERAGE_REPORT_PATH=
COVERAGE_MIN_PERCENT=80               # A3 flags changed files below this line-coverage %

# A4 Tech-Debt Scorecard signals (Phase 7). Each runs as its own CI step and
# writes a report; set the path to ingest it. Empty = that signal is skipped.
JSCPD_REPORT_PATH=                    # jscpd duplication JSON (--reporters json)
SONARQUBE_SARIF_PATH=                 # SonarQube issues exported as SARIF

# Standard-mapping layer (Phase 4). Which rule packs are active:
#   empty (default) -> none (findings carry no control_id; behaviour unchanged)
#   "*"             -> every discovered pack
#   CSV of ids      -> just those, e.g. "terraform-cis-aws"
# An active pack maps findings to standard controls + a ✅/◐/○ state and turns on
# gap detection (missing README/LICENSE/... -> human_only findings).
ENABLED_RULE_PACKS=
# Optional directory of extra/custom rule-pack JSON (built-ins ship with the engine).
RULE_PACKS_DIR=

# Wedge lenses (Phase 5). Each enforces a golden-standard definition:
#   empty (default) -> the lens is off (behaviour unchanged)
#   "default"       -> the built-in definition shipped with the engine
#   a path          -> a custom definition JSON (your own house standard)
# A1 Terraform Standardiser: golden module structure (required files + the
# expected terraform{} required_version/required_providers/backend blocks).
TERRAFORM_STANDARD=
# A2 CI/CD Standardiser: golden .github/workflows posture (no pull_request_target,
# SHA-pinned actions, a least-privilege top-level permissions block).
CICD_STANDARD=
# A5 GDS Readiness Scanner: empty=off · "default"=built-in points · a path=custom.
# Per-point ✅/◐/○ over the code-evidenceable GDS/TCoP points; out-of-scope
# (rendered/judgement) points are reported honestly, never faked.
GDS_STANDARD=

# Output surfaces (Phase 8). All written every run; CI uploads them. The SARIF
# lands in code-scanning; the evidence pack (HTML, prints to PDF) + CSV are the
# downloadable ✅/◐/○ deliverable.
FINDINGS_OUTPUT_PATH=./findings.json
SARIF_OUTPUT_PATH=./findings.sarif
EVIDENCE_HTML_PATH=./evidence-pack.html
EVIDENCE_CSV_PATH=./findings.csv

# Hosted dashboard ingest (Phase 9). After each scan the findings.json is POSTed
# here for per-standard readiness history + cross-repo rollups. Empty = off (no
# POST, behaviour unchanged). The POST is best-effort: a failure is logged and
# never fails the scan or blocks the PR comment.
DASHBOARD_INGEST_URL=                 # e.g. https://dashboard.example/api/ingest
DASHBOARD_API_KEY=                    # sent as `Authorization: Bearer <key>`
DASHBOARD_TIMEOUT_SECONDS=30

SQLITE_PATH=./data/state.sqlite

# GitHub access (for reading PRs and posting the sticky comment)
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_PR_NUMBER=

# Infracost (cost agent). Set the key to enable cost review; leave it empty to
# skip the cost agent entirely.
INFRACOST_API_KEY=
# Optional pre-built baseline JSON (base-ref breakdown). Leave empty to have the
# agent generate it from the workspace's git history automatically.
INFRACOST_BASELINE_PATH=

# CI gating: critical | high | medium | low | info | none
# "none" always exits 0; otherwise the run exits non-zero when a finding's
# severity meets or exceeds this floor (the comment is still posted first).
FAIL_ON_SEVERITY=none

# Where the PR head is checked out (scanners run here); defaults to the CWD
WORKSPACE_DIR=.

# Optional observability
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=terraform-review-agent

LOG_LEVEL=INFO
ENVIRONMENT=development               # development | staging | production
