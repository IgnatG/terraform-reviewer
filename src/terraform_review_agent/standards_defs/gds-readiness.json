{
  "id": "gds-readiness",
  "name": "GDS / Technology Code of Practice readiness (code-evidenceable subset)",
  "version": "1.0.0",
  "source_url": "https://www.gov.uk/guidance/the-technology-code-of-practice",
  "points": [
    {
      "id": "components-govuk-frontend",
      "title": "Uses the GOV.UK Frontend component library",
      "source_url": "https://frontend.design-system.service.gov.uk/",
      "check": "dependency",
      "target": "govuk-frontend",
      "state": "verified",
      "severity": "low"
    },
    {
      "id": "opensource-licence",
      "title": "Code is published under an open licence",
      "source_url": "https://www.gov.uk/government/publications/open-source-guidance",
      "check": "file",
      "target": "LICENSE,LICENSE.md,LICENCE,LICENCE.md,COPYING",
      "state": "verified",
      "severity": "low"
    },
    {
      "id": "opensource-readme",
      "title": "Repository documents the service (README)",
      "source_url": "https://www.gov.uk/service-manual/technology/making-source-code-open-and-reusable",
      "check": "file",
      "target": "README.md,README.rst,README.txt,docs/README.md",
      "state": "verified",
      "severity": "low"
    },
    {
      "id": "accessibility-statement-present",
      "title": "An accessibility statement is present",
      "source_url": "https://www.gov.uk/guidance/make-your-website-or-app-accessible-and-publish-an-accessibility-statement",
      "check": "file",
      "target": "accessibility-statement.md,accessibility.md,public/accessibility-statement.html,app/views/accessibility-statement.html",
      "state": "verified",
      "severity": "medium"
    },
    {
      "id": "secure-secrets-in-history",
      "title": "No secrets committed in git history",
      "source_url": "https://www.gov.uk/service-manual/technology/securing-your-information",
      "check": "out_of_scope",
      "state": "evidence"
    },
    {
      "id": "accessibility-wcag-rendered",
      "title": "Pages meet WCAG 2.2 AA (automated rendered checks)",
      "source_url": "https://www.gov.uk/service-manual/helping-people-to-use-your-service/testing-for-accessibility",
      "check": "out_of_scope",
      "state": "human_only"
    },
    {
      "id": "content-designed-to-gds",
      "title": "Content is designed to GDS content standards",
      "source_url": "https://www.gov.uk/guidance/content-design",
      "check": "out_of_scope",
      "state": "human_only"
    }
  ]
}
